  "keyFeatures": [
    "Column-oriented storage for analytical queries",
    "Real-time data ingestion and query processing",
    "Distributed query execution across clusters",
    "MergeTree engine family with advanced optimizations",
    "SQL query language with extensive function library",
    "Native replication and high availability",
    "Horizontal scalability for petabyte-scale data",
    "Multiple data format support (JSON, Parquet, CSV, etc.)",
    "Integration with external systems (Kafka, MySQL, PostgreSQL)",
    "ClickHouse Keeper for distributed coordination"
  ],
  "publicApiSurface": [
    "SELECT queries with JOINs, subqueries, and aggregations",
    "INSERT and INSERT SELECT statements",
    "ALTER TABLE operations (add/drop columns, modify settings)",
    "CREATE/DROP TABLE with various engine types",
    "MergeTree engine family (MergeTree, ReplicatedMergeTree, SummingMergeTree, AggregatingMergeTree)",
    "800+ built-in functions (aggregate, string, array, datetime, mathematical)",
    "HTTP interface for queries and data ingestion",
    "Native TCP protocol client interface",
    "Table functions (file, url, remote, s3, jdbc)",
    "Database engines (Atomic, Replicated, MySQL, PostgreSQL)",
    "Data types (numeric, string, date/time, arrays, tuples, nested)",
    "System tables for monitoring and introspection",
    "User-defined functions (UDFs)",
    "Materialized views for real-time aggregations",
    "Dictionaries for dimension data caching",
    "Distributed tables for query federation",
    "clickhouse-client CLI tool",
    "clickhouse-local for local file processing",
    "clickhouse-keeper for distributed coordination"
  ]
